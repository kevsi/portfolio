---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";
---

<Layout title="Inscription">
  <Container>
    <Sectionhead>
      <Fragment slot="title">Inscription</Fragment>
      <Fragment slot="desc">Créez votre compte gratuitement</Fragment>
    </Sectionhead>

    <div class="mx-auto max-w-md mt-12">
      <form id="register-form" class="space-y-4">
        <div>
          <label for="full-name" class="block text-sm font-medium text-gray-700">Nom complet</label>
          <input
            type="text"
            id="full-name"
            name="full-name"
            required
            class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-indigo-500"
          />
        </div>

        <div>
          <label for="username" class="block text-sm font-medium text-gray-700">Nom d'utilisateur</label>
          <input
            type="text"
            id="username"
            name="username"
            required
            class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-indigo-500"
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-medium text-gray-700">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-indigo-500"
          />
        </div>

        <div>
          <label for="password" class="block text-sm font-medium text-gray-700">Mot de passe</label>
          <input
            type="password"
            id="password"
            name="password"
            minlength="6"
            required
            class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-indigo-500"
          />
          <p class="mt-1 text-xs text-gray-500">Minimum 6 caractères</p>
        </div>

        <div>
          <label for="confirm-password" class="block text-sm font-medium text-gray-700">Confirmer le mot de passe</label>
          <input
            type="password"
            id="confirm-password"
            name="confirm-password"
            minlength="6"
            required
            class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-indigo-500"
          />
        </div>

        <!-- Avatar Selection -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Choisissez un avatar</label>
          <div id="avatar-loading" class="text-sm text-gray-500">Chargement des avatars...</div>
          <div id="avatar-grid" class="grid grid-cols-4 gap-2 hidden"></div>
          <input type="hidden" id="selected-avatar-id" name="avatar-id" />
          <input type="hidden" id="selected-avatar-lottie" name="avatar-lottie" />
          <input type="hidden" id="selected-avatar-preview" name="avatar-preview" />
        </div>

        <button
          type="submit"
          id="submit-btn"
          class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 disabled:opacity-50 disabled:cursor-not-allowed"
        >
          S'inscrire
        </button>

        <div id="error-message" class="hidden text-red-600 text-sm text-center rounded-md bg-red-50 px-3 py-2"></div>
        <div id="success-message" class="hidden text-green-600 text-sm text-center rounded-md bg-green-50 px-3 py-2"></div>
      </form>

      <p class="mt-4 text-center text-sm text-gray-600">
        Déjà un compte ?
        <a href="/auth/login" class="font-medium text-indigo-600 hover:text-indigo-500">
          Se connecter
        </a>
      </p>
    </div>
  </Container>
</Layout>

<script>
  import { supabase } from '../../lib/supabase';
  import { loadLottieScript, createLottie, isLottieLoaded } from '../../utils/lottie';

  interface Avatar {
    id: string;
    name: string;
    lottie_url: string;
    preview_url: string | null;
    is_free: boolean;
  }

  let freeAvatars: Avatar[] = [];
  let selectedAvatar: Avatar | null = null;

  // ── Load avatars ─────────────────────────────────────────────────────────
  async function loadAvatars() {
    try {
      const { data: avatars, error } = await supabase
        .from('avatars')
        .select('*')
        .eq('is_free', true)
        .order('name')
        .limit(8);

      if (error) throw error;
      freeAvatars = avatars || [];

      // ✅ Fix 2 — Load Lottie FIRST, then render cards
      await loadLottieScript();
      renderAvatars();
    } catch (err) {
      console.error('Erreur chargement avatars:', err);
      document.getElementById('avatar-loading')?.classList.add('hidden');
    }
  }

  function renderAvatars() {
    const grid = document.getElementById('avatar-grid');
    const loading = document.getElementById('avatar-loading');
    if (!grid || freeAvatars.length === 0) return;

    loading?.classList.add('hidden');
    grid.classList.remove('hidden');

    grid.innerHTML = freeAvatars.map((avatar, index) => {
      const hasPreview = !!avatar.preview_url?.trim();
      return `
      <div class="avatar-option relative cursor-pointer rounded-lg overflow-hidden border-2
                  ${index === 0 ? 'border-indigo-600 ring-2 ring-indigo-200' : 'border-gray-200 hover:border-indigo-300'}
                  transition-all"
           data-id="${avatar.id}"
           data-lottie="${avatar.lottie_url}"
           data-preview="${avatar.preview_url || ''}"
           data-has-preview="${hasPreview}">
        <div class="aspect-square bg-gray-50 relative">
          ${hasPreview ? `
            <img src="${avatar.preview_url}" alt="${avatar.name}"
                 class="avatar-static absolute inset-0 w-full h-full object-cover transition-opacity duration-200" />
            <div class="avatar-lottie absolute inset-0 opacity-0 transition-opacity duration-200 pointer-events-none"></div>
          ` : `
            <div class="avatar-lottie-direct absolute inset-0 pointer-events-none"></div>
          `}
        </div>
      </div>`;
    }).join('');

    // Select first by default
    if (freeAvatars.length > 0) selectAvatar(freeAvatars[0]);

    // ✅ Fix 2 — Init direct Lottie cards now that lottie is loaded
    grid.querySelectorAll<HTMLElement>('.avatar-lottie-direct').forEach(div => {
      const url = div.closest<HTMLElement>('.avatar-option')?.dataset.lottie;
      if (url) createLottie(div, url, 0.6);
    });

    // Hover + click events
    grid.querySelectorAll<HTMLElement>('.avatar-option').forEach(card => {
      const hasPreview = card.dataset.hasPreview === 'true';
      let anim: any = null;

      if (hasPreview) {
        const staticImg = card.querySelector<HTMLElement>('.avatar-static')!;
        const lottieDiv = card.querySelector<HTMLElement>('.avatar-lottie')!;
        const url = card.dataset.lottie!;

        card.addEventListener('mouseenter', () => {
          if (!isLottieLoaded()) return;
          staticImg.style.opacity = '0';
          lottieDiv.style.opacity = '1';
          if (!anim) anim = createLottie(lottieDiv, url);
          else anim.play();
        });
        card.addEventListener('mouseleave', () => {
          staticImg.style.opacity = '1';
          lottieDiv.style.opacity = '0';
          anim?.pause();
        });
      }

      card.addEventListener('click', () => {
        const avatar = freeAvatars.find(a => a.id === card.dataset.id);
        if (!avatar) return;
        selectAvatar(avatar);
        grid.querySelectorAll('.avatar-option').forEach(c => {
          c.classList.remove('border-indigo-600', 'ring-2', 'ring-indigo-200');
          c.classList.add('border-gray-200');
        });
        card.classList.remove('border-gray-200');
        card.classList.add('border-indigo-600', 'ring-2', 'ring-indigo-200');
      });
    });
  }

  function selectAvatar(avatar: Avatar) {
    selectedAvatar = avatar;
    (document.getElementById('selected-avatar-id') as HTMLInputElement).value = avatar.id;
    (document.getElementById('selected-avatar-lottie') as HTMLInputElement).value = avatar.lottie_url;
    (document.getElementById('selected-avatar-preview') as HTMLInputElement).value = avatar.preview_url ?? '';
  }

  // ── Form submit ───────────────────────────────────────────────────────────
  const form = document.getElementById('register-form') as HTMLFormElement;
  const errorMessage = document.getElementById('error-message')!;
  const successMessage = document.getElementById('success-message')!;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  function showError(msg: string) {
    errorMessage.textContent = msg;
    errorMessage.classList.remove('hidden');
    successMessage.classList.add('hidden');
  }

  function showSuccess(msg: string) {
    successMessage.textContent = msg;
    successMessage.classList.remove('hidden');
    errorMessage.classList.add('hidden');
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorMessage.classList.add('hidden');
    successMessage.classList.add('hidden');
    submitBtn.disabled = true;
    submitBtn.textContent = 'Inscription en cours...';

    const formData = new FormData(form);
    const email = formData.get('email') as string;
    const password = formData.get('password') as string;
    const confirmPassword = formData.get('confirm-password') as string;
    const fullName = formData.get('full-name') as string;
    const username = formData.get('username') as string;

    if (password !== confirmPassword) {
      showError('Les mots de passe ne correspondent pas');
      submitBtn.disabled = false;
      submitBtn.textContent = "S'inscrire";
      return;
    }

    try {
      const res = await fetch('/api/auth/register', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email,
          password,
          fullName,
          username,
          avatarId: selectedAvatar?.id ?? null,
          avatarLottieUrl: selectedAvatar?.lottie_url ?? null,
          avatarUrl: selectedAvatar?.preview_url ?? null,
        }),
      });

      const data = await res.json();

      if (!res.ok) {
        throw new Error(data.error || "Erreur lors de l'inscription");
      }

      if (data.hasSession) {
        // Session active (email confirmation désactivé) → stocker pour header
        localStorage.setItem('auth_user', JSON.stringify({
          id: data.user.id,
          email,
          full_name: fullName,
          username,
          avatar_url: selectedAvatar?.preview_url ?? '',
          avatar_lottie_url: selectedAvatar?.lottie_url ?? '',
        }));
      }

      showSuccess('Inscription réussie ! Redirection...');
      setTimeout(() => {
        window.location.href = data.hasSession ? '/' : '/auth/login';
      }, 1500);

    } catch (error: any) {
      const msg =
        error.message === 'User already registered'
          ? 'Un compte existe déjà avec cet email'
          : error.message?.includes('rate limit')
          ? 'Trop de tentatives. Réessayez dans quelques minutes.'
          : error.message || "Une erreur est survenue lors de l'inscription";
      showError(msg);
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = "S'inscrire";
    }
  });

  // Load avatars on page load
  loadAvatars();
</script>