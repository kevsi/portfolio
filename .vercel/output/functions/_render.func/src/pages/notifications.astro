---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";
import { supabase } from '@lib/supabase';
import { getNotifications, getUnreadCount } from '@lib/notifications';

// Check authentication (middleware ensures session exists for protected routes)
const session = Astro.locals.session;

if (!session) {
  return Astro.redirect('/auth/login');
}

// Get notifications data
let notifications = [];
let unreadCount = 0;
let currentFilter = Astro.url.searchParams.get('filter') || 'all';

try {
  notifications = await getNotifications(session.user.id, 20);
  unreadCount = await getUnreadCount(session.user.id);
  
  // Filter by type if specified
  if (currentFilter !== 'all') {
    notifications = notifications.filter(n => n.type === currentFilter);
  }
} catch (error) {
  console.error('Error loading notifications:', error);
}
---

<Layout title="Notifications">
  <Container>
    <Sectionhead>
      <Fragment slot="title">Notifications</Fragment>
      <Fragment slot="desc">Restez informé de vos dernières activités</Fragment>
    </Sectionhead>

    <!-- Notification Filters -->
    <div class="bg-white rounded-lg border border-gray-200 p-4 mb-6">
      <div class="flex flex-col md:flex-row gap-4 items-center justify-between">
        <h2 class="text-lg font-semibold text-gray-900">Filtrer les notifications</h2>
        <div class="flex flex-wrap gap-2">
          <a href="/notifications?filter=all" class={`filter-btn px-3 py-1 text-sm rounded-full transition-colors ${currentFilter === 'all' ? 'bg-indigo-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}`}>
            Toutes {unreadCount > 0 && `(${unreadCount})`}
          </a>
          <a href="/notifications?filter=order" class={`filter-btn px-3 py-1 text-sm rounded-full transition-colors ${currentFilter === 'order' ? 'bg-indigo-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}`}>
            Commandes
          </a>
          <a href="/notifications?filter=system" class={`filter-btn px-3 py-1 text-sm rounded-full transition-colors ${currentFilter === 'system' ? 'bg-indigo-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}`}>
            Système
          </a>
          <a href="/notifications?filter=avatar" class={`filter-btn px-3 py-1 text-sm rounded-full transition-colors ${currentFilter === 'avatar' ? 'bg-indigo-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}`}>
            Avatars
          </a>
          <a href="/notifications?filter=promotion" class={`filter-btn px-3 py-1 text-sm rounded-full transition-colors ${currentFilter === 'promotion' ? 'bg-indigo-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}`}>
            Promotions
          </a>
        </div>
      </div>
    </div>

    <!-- Empty Notifications -->
    {notifications.length === 0 && (
      <div class="text-center py-16">
        <div class="max-w-md mx-auto">
          <div class="w-24 h-24 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-12 h-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">
            {currentFilter === 'all' ? 'Aucune notification' : `Aucune notification ${currentFilter}`}
          </h3>
          <p class="text-gray-600">
            {currentFilter === 'all' 
              ? 'Vous n\'avez pas de nouvelles notifications pour le moment.' 
              : `Vous n'avez pas de notifications de type ${currentFilter}.`}
          </p>
        </div>
      </div>
    )}

    <!-- Notifications List -->
    {notifications.length > 0 && (
      <div>
        {unreadCount > 0 && (
          <div class="mb-4">
            <button id="mark-all-read" class="px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition-colors">
              Tout marquer comme lu ({unreadCount})
            </button>
          </div>
        )}
        
        <div class="space-y-3" id="notifications-list">
          {notifications.map(notification => {
            const typeConfig = {
              order: { icon: '📦', bg: 'bg-blue-50', color: 'text-blue-600', border: 'border-blue-200' },
              system: { icon: '⚙️', bg: 'bg-gray-50', color: 'text-gray-600', border: 'border-gray-200' },
              avatar: { icon: '🎭', bg: 'bg-purple-50', color: 'text-purple-600', border: 'border-purple-200' },
              promotion: { icon: '🎉', bg: 'bg-amber-50', color: 'text-amber-600', border: 'border-amber-200' },
              social: { icon: '💬', bg: 'bg-green-50', color: 'text-green-600', border: 'border-green-200' },
            };
            const cfg = typeConfig[notification.type] || typeConfig.system;
            return (
            <div class={`notification-item group bg-white rounded-xl border p-4 hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200 cursor-pointer ${!notification.is_read ? `border-l-4 border-l-indigo-500 bg-indigo-50/50` : `border ${cfg.border}`}`} 
                 data-id={notification.id} 
                 data-read={notification.is_read}
                 data-url={notification.action_url || ''}>
              <div class="flex gap-4">
                <div class="flex-shrink-0">
                  <div class={`w-12 h-12 rounded-xl flex items-center justify-center text-2xl ${cfg.bg} border ${cfg.border}`}>
                    {cfg.icon}
                  </div>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-start justify-between gap-2">
                    <h3 class="font-semibold text-gray-900 text-sm group-hover:text-indigo-600 transition-colors">{notification.title}</h3>
                    {!notification.is_read && (
                      <button class="mark-read-btn flex-shrink-0 px-2.5 py-1 text-xs text-indigo-600 bg-indigo-50 hover:bg-indigo-100 rounded-lg transition-colors" data-id={notification.id}>
                        Marquer lu
                      </button>
                    )}
                  </div>
                  <p class="text-gray-500 text-sm mt-1 line-clamp-2">{notification.message}</p>
                  <p class="text-gray-400 text-xs mt-2">{getRelativeTime(notification.created_at)}</p>
                </div>
              </div>
            </div>
          );
          })}
        </div>
      </div>
    )}
  </Container>
</Layout>

<script>
  import { supabase } from '../lib/supabase';
  import { markAsRead, markAllAsRead } from '../lib/notifications';
  import { showToast } from '../utils/ui';

  let currentUserId = '{session.user.id}';

  // Mark notification as read
  async function markAsReadHandler(notificationId) {
    try {
      await markAsRead(currentUserId, notificationId);
      
      // Update UI
      const notificationElement = document.querySelector(`[data-id="${notificationId}"]`);
      if (notificationElement) {
        notificationElement.classList.remove('border-l-4', 'border-l-indigo-500', 'bg-indigo-50');
        notificationElement.dataset.read = 'true';
        
        // Remove the mark as read button
        const markReadBtn = notificationElement.querySelector('.mark-read-btn');
        if (markReadBtn) {
          markReadBtn.closest('.flex-shrink-0').remove();
        }
      }

      // Update header notification badge
      window.dispatchEvent(new CustomEvent('notification-read'));
      
      showToast('Notification marquée comme lue');
    } catch (error) {
      console.error('Error marking as read:', error);
      showToast('Erreur lors de la mise à jour', true);
    }
  }

  // Mark all as read
  async function markAllAsReadHandler() {
    try {
      await markAllAsRead(currentUserId);
      
      // Update all UI elements
      document.querySelectorAll('.notification-item').forEach(item => {
        item.classList.remove('border-l-4', 'border-l-indigo-500', 'bg-indigo-50');
        item.dataset.read = 'true';
        
        // Remove mark as read buttons
        const markReadBtn = item.querySelector('.mark-read-btn');
        if (markReadBtn) {
          markReadBtn.closest('.flex-shrink-0').remove();
        }
      });

      // Hide the mark all as read button
      const markAllBtn = document.getElementById('mark-all-read');
      if (markAllBtn) {
        markAllBtn.style.display = 'none';
      }

      // Update header notification badge
      window.dispatchEvent(new CustomEvent('all-notifications-read'));
      
      showToast('Toutes les notifications marquées comme lues');
    } catch (error) {
      console.error('Error marking all as read:', error);
      showToast('Erreur lors de la mise à jour', true);
    }
  }


  // Event listeners
  document.addEventListener('DOMContentLoaded', () => {
    // Mark as read buttons
    document.querySelectorAll('.mark-read-btn').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        e.stopPropagation();
        const notificationId = e.target.dataset.id;
        await markAsReadHandler(notificationId);
      });
    });

    // Mark all as read button
    document.getElementById('mark-all-read')?.addEventListener('click', markAllAsReadHandler);

    // Notification click handlers
    document.querySelectorAll('.notification-item').forEach(item => {
      item.addEventListener('click', async (e) => {
        // Don't trigger if clicking on the mark as read button
        if (e.target.closest('.mark-read-btn')) return;
        
        const notificationId = item.dataset.id;
        const actionUrl = item.dataset.url;
        const isRead = item.dataset.read === 'true';
        
        // Mark as read if not already
        if (!isRead) {
          await markAsReadHandler(notificationId);
        }
        
        // Navigate to action URL if available
        if (actionUrl) {
          window.location.href = actionUrl;
        }
      });
    });
  });
</script>

<style>
  .notification-item {
    transition: all 0.2s ease;
  }
  
  .notification-item:hover {
    transform: translateY(-1px);
  }
  
  .filter-btn {
    transition: all 0.2s ease;
  }
  
  .filter-btn:hover {
    transform: translateY(-1px);
  }
</style>
