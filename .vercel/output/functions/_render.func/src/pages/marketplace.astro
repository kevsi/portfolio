---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";

const categories = [
  { name: 'All', icon: '✦' },
  { name: 'UI Kits', icon: '◈' },
  { name: 'Templates', icon: '◇' },
  { name: 'Icons', icon: '◆' },
  { name: 'Illustrations', icon: '◎' },
  { name: 'Fonts', icon: '▣' },
  { name: 'Animations', icon: '▷' },
  { name: 'Components', icon: '⬡' },
];
---

<Layout title="Marketplace">
  <div class="min-h-screen bg-gray-50/50">
    <!-- Hero Section -->
    <div class="relative overflow-hidden bg-gradient-to-br from-violet-600 via-indigo-600 to-blue-600">
      <div class="absolute inset-0 opacity-[0.08]">
        <svg width="100%" height="100%"><defs><pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse"><path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="1"/></pattern></defs><rect width="100%" height="100%" fill="url(#grid)"/></svg>
      </div>
      <div class="absolute top-0 right-0 w-96 h-96 bg-white/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
      <div class="absolute bottom-0 left-0 w-72 h-72 bg-white/10 rounded-full blur-3xl translate-y-1/2 -translate-x-1/2"></div>
      
      <div class="relative max-w-7xl mx-auto px-6 py-16 lg:py-20">
        <div class="text-center">
          <span class="inline-flex items-center gap-2 px-4 py-1.5 bg-white/15 backdrop-blur-sm text-white/90 text-sm font-medium rounded-full mb-6 border border-white/10">
            <span class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></span>
            Marketplace
          </span>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white tracking-tight mb-4">
            Découvrez des assets<br/>
            <span class="bg-gradient-to-r from-violet-200 to-blue-200 bg-clip-text text-transparent">exceptionnels</span>
          </h1>
          <p class="text-lg text-white/70 max-w-2xl mx-auto mb-8">
            Templates, icônes, illustrations et composants créés par des designers talentueux.
          </p>
          
          <!-- Search Bar Hero -->
          <div class="max-w-2xl mx-auto">
            <div class="relative group">
              <div class="absolute -inset-0.5 bg-gradient-to-r from-white/20 to-white/10 rounded-2xl blur opacity-0 group-hover:opacity-100 transition duration-300"></div>
              <div class="relative flex items-center bg-white rounded-2xl shadow-2xl shadow-black/10">
                <svg class="absolute left-5 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
                <input 
                  type="text" 
                  id="search-input" 
                  placeholder="Rechercher des assets, auteurs, catégories..."
                  class="w-full py-4 pl-14 pr-4 text-gray-900 placeholder-gray-400 bg-transparent rounded-2xl focus:outline-none"
                />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <Container>
      <!-- Stats -->
      <div class="grid grid-cols-3 gap-4 -mt-8 mb-10 relative z-10">
        <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 text-center hover:shadow-md transition-shadow">
          <div class="w-10 h-10 bg-violet-100 rounded-xl flex items-center justify-center mx-auto mb-3">
            <svg class="w-5 h-5 text-violet-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
          </div>
          <div id="stat-total" class="text-2xl font-bold text-gray-900">-</div>
          <div class="text-sm text-gray-500 mt-0.5">Assets</div>
        </div>
        <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 text-center hover:shadow-md transition-shadow">
          <div class="w-10 h-10 bg-blue-100 rounded-xl flex items-center justify-center mx-auto mb-3">
            <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
          </div>
          <div id="stat-creators" class="text-2xl font-bold text-gray-900">-</div>
          <div class="text-sm text-gray-500 mt-0.5">Créateurs</div>
        </div>
        <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 text-center hover:shadow-md transition-shadow">
          <div class="w-10 h-10 bg-emerald-100 rounded-xl flex items-center justify-center mx-auto mb-3">
            <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
          </div>
          <div id="stat-downloads" class="text-2xl font-bold text-gray-900">-</div>
          <div class="text-sm text-gray-500 mt-0.5">Téléchargements</div>
        </div>
      </div>

      <!-- Filters Row -->
      <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-4 mb-6">
        <!-- Categories -->
        <div class="flex flex-wrap gap-2" id="category-tabs">
          {categories.map((cat) => (
            <button 
              data-category={cat.name}
              class={`flex items-center gap-1.5 px-4 py-2 text-sm font-medium rounded-xl transition-all duration-200 ${
                cat.name === 'All' 
                  ? 'bg-gray-900 text-white shadow-sm' 
                  : 'bg-white text-gray-600 border border-gray-200 hover:border-gray-300 hover:bg-gray-50'
              }`}
            >
              <span class="text-xs opacity-70">{cat.icon}</span>
              {cat.name}
            </button>
          ))}
        </div>
        
        <!-- Right filters -->
        <div class="flex items-center gap-3">
          <select id="price-filter" class="px-4 py-2 text-sm bg-white border border-gray-200 rounded-xl focus:border-violet-500 focus:outline-none text-gray-600">
            <option value="all">Tous les prix</option>
            <option value="free">Gratuit</option>
            <option value="paid">Payant</option>
          </select>
          <select id="sort-select" class="px-4 py-2 text-sm bg-white border border-gray-200 rounded-xl focus:border-violet-500 focus:outline-none text-gray-600">
            <option value="popular">Populaires</option>
            <option value="newest">Récents</option>
            <option value="price-asc">Prix ↑</option>
            <option value="price-desc">Prix ↓</option>
            <option value="rating">Meilleures notes</option>
          </select>
        </div>
      </div>

      <!-- Count -->
      <div class="flex items-center justify-between mb-6">
        <p class="text-sm text-gray-500"><span id="asset-count" class="font-semibold text-gray-900">0</span> résultats</p>
      </div>

      <!-- Asset Grid -->
      <div id="assets-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5 pb-20"></div>

      <!-- No Results -->
      <div id="no-results" class="hidden text-center py-20">
        <div class="w-20 h-20 bg-gray-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-10 h-10 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-1">Aucun résultat</h3>
        <p class="text-gray-500">Essayez de modifier vos filtres ou votre recherche.</p>
      </div>

      <!-- Loading -->
      <div id="loading" class="text-center py-20">
        <div class="inline-block w-10 h-10 border-3 border-violet-200 border-t-violet-600 rounded-full animate-spin"></div>
        <p class="mt-4 text-gray-500">Chargement des assets...</p>
      </div>
    </Container>
  </div>
</Layout>

<script>
  import { supabase } from '../lib/supabase';

  const categoryIcons = {
    'All': '✦', 'UI Kits': '◈', 'Templates': '◇', 'Icons': '◆',
    'Illustrations': '◎', 'Fonts': '▣', 'Animations': '▷', 'Components': '⬡'
  };

  let allAssets = [];
  let currentCategory = 'All';
  let searchQuery = '';
  let priceFilter = 'all';
  let sortBy = 'popular';

  const loadingEl = document.getElementById('loading');
  const contentEl = document.getElementById('content');
  const searchInput = document.getElementById('search-input');
  const priceFilterSelect = document.getElementById('price-filter');
  const sortSelect = document.getElementById('sort-select');
  const assetsGrid = document.getElementById('assets-grid');
  const assetCount = document.getElementById('asset-count');
  const noResults = document.getElementById('no-results');
  const categoryTabs = document.getElementById('category-tabs');

  function mapAsset(asset) {
    const creator = asset.profiles;
    return {
      id: asset.id,
      name: asset.title,
      author: creator ? (creator.full_name || creator.username || 'Anonyme') : 'Anonyme',
      category: asset.category || 'Templates',
      price: asset.price || 0,
      rating: asset.rating || 0,
      downloads: asset.downloads || 0,
      badge: asset.badge,
      previewBg: asset.preview_bg || 'bg-gradient-to-br from-violet-400 to-indigo-600',
      description: asset.description || ''
    };
  }

  async function loadAssets() {
    try {
      const { data: assets, error } = await supabase
        .from('assets')
        .select('*, profiles:user_id(full_name, username)')
        .order('created_at', { ascending: false });

      if (error) throw error;

      allAssets = (assets || []).map(mapAsset);
      updateStats();
      loadingEl?.classList.add('hidden');
      refresh();
    } catch (error) {
      console.error('Erreur chargement assets:', error);
      loadingEl.innerHTML = '<div class="w-20 h-20 bg-red-50 rounded-2xl flex items-center justify-center mx-auto mb-4"><svg class="w-10 h-10 text-red-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg></div><p class="text-gray-500">Erreur lors du chargement</p>';
    }
  }

  function updateStats() {
    document.getElementById('stat-total').textContent = allAssets.length;
    document.getElementById('stat-creators').textContent = [...new Set(allAssets.map(a => a.author))].length;
    const totalDl = allAssets.reduce((s, a) => s + a.downloads, 0);
    document.getElementById('stat-downloads').textContent = totalDl > 999 ? (totalDl / 1000).toFixed(0) + 'k' : totalDl;
  }

  function filterAndSort() {
    let filtered = [...allAssets];
    if (currentCategory !== 'All') filtered = filtered.filter(a => a.category === currentCategory);
    if (priceFilter === 'free') filtered = filtered.filter(a => a.price === 0);
    else if (priceFilter === 'paid') filtered = filtered.filter(a => a.price > 0);
    if (searchQuery) {
      const q = searchQuery.toLowerCase();
      filtered = filtered.filter(a => a.name.toLowerCase().includes(q) || a.author.toLowerCase().includes(q) || a.category.toLowerCase().includes(q));
    }
    switch (sortBy) {
      case 'popular': filtered.sort((a, b) => b.downloads - a.downloads); break;
      case 'newest': filtered.sort((a, b) => b.id.localeCompare(a.id)); break;
      case 'price-asc': filtered.sort((a, b) => a.price - b.price); break;
      case 'price-desc': filtered.sort((a, b) => b.price - a.price); break;
      case 'rating': filtered.sort((a, b) => b.rating - a.rating); break;
    }
    return filtered;
  }

  function renderAssets(toRender) {
    assetCount.textContent = toRender.length;
    if (toRender.length === 0) { assetsGrid.classList.add('hidden'); noResults.classList.remove('hidden'); return; }
    assetsGrid.classList.remove('hidden'); noResults.classList.add('hidden');

    assetsGrid.innerHTML = toRender.map((asset, i) => {
      const isFree = asset.price === 0;
      const stars = '★'.repeat(Math.round(asset.rating)) + '☆'.repeat(5 - Math.round(asset.rating));

      return `<a href="/marketplace/${asset.id}" class="block group" style="animation: fadeInUp 0.3s ease ${i * 0.04}s both">
        <div class="bg-white rounded-2xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-xl hover:border-gray-200 hover:-translate-y-1 transition-all duration-300">
          <!-- Preview -->
          <div class="relative h-48 ${asset.previewBg} overflow-hidden">
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-colors duration-300"></div>
            <div class="absolute inset-0 flex items-center justify-center">
              <svg class="w-16 h-16 text-white/20" fill="currentColor" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6z"/></svg>
            </div>
            <!-- Quick action overlay -->
            <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <span class="px-4 py-2 bg-white/95 backdrop-blur-sm text-gray-900 text-sm font-semibold rounded-xl shadow-lg">Voir le détail →</span>
            </div>
            <!-- Badge -->
            ${asset.badge ? `<span class="absolute top-3 left-3 px-2.5 py-1 text-xs font-bold rounded-lg ${isFree ? 'bg-emerald-500' : 'bg-violet-500'} text-white shadow-sm">${asset.badge}</span>` : ''}
            <!-- Price pill -->
            <span class="absolute top-3 right-3 px-3 py-1 text-sm font-bold rounded-lg ${isFree ? 'bg-white/90 text-emerald-600' : 'bg-white/90 text-gray-900'} backdrop-blur-sm shadow-sm">
              ${isFree ? 'Gratuit' : asset.price + '€'}
            </span>
          </div>
          
          <!-- Info -->
          <div class="p-4">
            <div class="flex items-start justify-between gap-2 mb-2">
              <h3 class="font-bold text-gray-900 truncate group-hover:text-violet-600 transition-colors">${asset.name}</h3>
            </div>
            <p class="text-sm text-gray-400 mb-3 truncate">${asset.author}</p>
            
            <!-- Category + Rating -->
            <div class="flex items-center justify-between">
              <span class="text-xs px-2 py-1 bg-gray-50 text-gray-500 rounded-lg font-medium">${asset.category}</span>
              <div class="flex items-center gap-3">
                <span class="text-xs text-amber-500">${stars}</span>
                <span class="text-xs text-gray-400 flex items-center gap-1">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
                  ${asset.downloads > 999 ? (asset.downloads / 1000).toFixed(1) + 'k' : asset.downloads}
                </span>
              </div>
            </div>
          </div>
        </div>
      </a>`;
    }).join('');
  }

  function updateCategoryTabs() {
    categoryTabs.querySelectorAll('button').forEach(btn => {
      const cat = btn.dataset.category;
      if (cat === currentCategory) {
        btn.classList.remove('bg-white', 'text-gray-600', 'border-gray-200');
        btn.classList.add('bg-gray-900', 'text-white');
      } else {
        btn.classList.remove('bg-gray-900', 'text-white');
        btn.classList.add('bg-white', 'text-gray-600', 'border-gray-200');
      }
    });
  }

  function refresh() { renderAssets(filterAndSort()); updateCategoryTabs(); }

  searchInput?.addEventListener('input', (e) => { searchQuery = e.target.value; refresh(); });
  priceFilterSelect?.addEventListener('change', (e) => { priceFilter = e.target.value; refresh(); });
  sortSelect?.addEventListener('change', (e) => { sortBy = e.target.value; refresh(); });
  categoryTabs?.addEventListener('click', (e) => { if (e.target.tagName === 'BUTTON') { currentCategory = e.target.dataset.category; refresh(); } });

  loadAssets();
</script>

<style>
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
