---
import { supabase } from '@lib/supabase';
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";

const { slug } = Astro.params;

const { data: post, error } = await supabase
  .from('blog_posts')
  .select('*')
  .eq('slug', slug)
  .eq('published', true)
  .single();

if (!post) {
  return Astro.redirect('/blog');
}

const formatDate = (date: string) =>
  new Date(date).toLocaleDateString("fr-FR", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
---

<Layout title={post.title}>
  <Container>
    <article class="mx-auto max-w-3xl mt-14">
      <!-- Back link -->
      <a href="/blog" class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-indigo-600 transition-colors mb-8">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Retour au blog
      </a>

      <!-- Category + Date -->
      <div class="flex items-center gap-3 mb-4">
        <span class="px-3 py-1 text-xs font-semibold uppercase tracking-wider text-indigo-600 bg-indigo-50 rounded-full">
          {post.category}
        </span>
        <time class="text-sm text-gray-500">
          {formatDate(post.publish_date)}
        </time>
      </div>

      <!-- Title -->
      <h1 class="text-3xl lg:text-5xl font-bold text-gray-900 leading-tight mb-4">
        {post.title}
      </h1>

      <!-- Snippet -->
      <p class="text-xl text-gray-600 mb-6">
        {post.snippet}
      </p>

      <!-- Author -->
      <div class="flex items-center gap-3 mb-8 pb-8 border-b border-gray-200">
        <div class="w-10 h-10 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-600 font-bold text-sm">
          {post.author.charAt(0)}
        </div>
        <div>
          <p class="font-medium text-gray-900">{post.author}</p>
          <div class="flex gap-2">
            {(post.tags || []).map((tag: string) => (
              <span class="text-xs text-gray-500">#{tag}</span>
            ))}
          </div>
        </div>
      </div>

      <!-- Featured Image -->
      {post.image_url && (
        <div class="rounded-xl overflow-hidden mb-10">
          <img
            src={post.image_url}
            alt={post.image_alt}
            class="w-full h-auto object-cover"
          />
        </div>
      )}

      <!-- Content (rendered from markdown stored in Supabase) -->
      <div class="prose prose-lg prose-indigo max-w-none" set:html={post.content.replace(/\n/g, '<br>').replace(/## (.*?)(<br>|$)/g, '<h2>$1</h2>').replace(/### (.*?)(<br>|$)/g, '<h3>$1</h3>').replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>').replace(/- (.*?)(<br>|$)/g, '<li>$1</li>').replace(/(<li>.*?<\/li>)+/g, (match) => `<ul>${match}</ul>`)
      } />

      <!-- Bottom nav -->
      <div class="mt-12 pt-8 border-t border-gray-200 text-center">
        <a
          href="/blog"
          class="inline-flex items-center gap-2 px-6 py-3 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 transition-colors font-medium"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          Retour au blog
        </a>
      </div>
    </article>
  </Container>
</Layout>
