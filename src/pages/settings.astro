---
import Layout from "@layouts/Layout.astro";

// Get session from middleware
const session = Astro.locals.session;
const userId = session?.user?.id ?? null;
---

<Layout title="Paramètres">
  <!-- Pass server data to client script -->
  {userId && <script is:inline define:vars={{ userId }}>window.__USER_ID__ = userId;</script>}
  <!-- Cover Section -->
  <div class="relative bg-gray-900 h-64 md:h-80">
    <div class="absolute inset-0 bg-gradient-to-b from-indigo-600 to-purple-700" id="cover-gradient">
      <img id="cover-img" class="w-full h-full object-cover opacity-50 hidden" alt="Cover" />
    </div>
    <div class="absolute inset-0 bg-black bg-opacity-20"></div>
    
    <!-- Cover Change Button -->
    <button id="change-cover-btn" class="absolute top-4 right-4 z-20 bg-white bg-opacity-90 hover:bg-opacity-100 text-gray-700 px-4 py-2 rounded-lg shadow-md flex items-center gap-2 transition-all">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
      </svg>
      <span class="text-sm font-medium">Changer la cover</span>
    </button>
    
    <!-- Hidden file input for cover upload -->
    <input type="file" id="cover-file-input" class="hidden" accept="image/*" />
    
    <div class="absolute bottom-0 left-0 right-0 transform translate-y-1/2 px-4 md:px-8">
      <div class="max-w-6xl mx-auto">
        <div class="flex flex-col md:flex-row items-end md:items-end gap-4">
          <div class="relative">
            <div id="large-avatar" class="w-32 h-32 md:w-40 md:h-40 rounded-full border-4 border-white bg-indigo-600 flex items-center justify-center text-white text-4xl md:text-5xl font-bold shadow-lg overflow-hidden">
              <span id="avatar-initials-large">U</span>
            </div>
            <button id="change-avatar-btn" class="absolute bottom-0 right-0 w-10 h-10 bg-white rounded-full shadow-md flex items-center justify-center text-gray-600 hover:text-gray-900 border-2 border-gray-100">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </button>
          </div>
          
          <div class="mb-2 md:mb-4 text-white md:text-gray-900">
            <h1 id="user-name" class="text-2xl md:text-3xl font-bold">Utilisateur</h1>
            <p id="user-username" class="text-sm opacity-80 md:text-gray-500">@username</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="max-w-6xl mx-auto px-4 md:px-8 pt-20 md:pt-24 pb-12">
    <div class="flex flex-col md:flex-row gap-6">
      
      <!-- Sidebar -->
      <aside class="w-full md:w-64 flex-shrink-0">
        <div class="bg-white rounded-lg shadow p-4 sticky top-4">
          <h2 class="text-lg font-semibold text-gray-900 mb-4 px-2">Paramètres</h2>
          <nav class="space-y-1">
            <button data-section="profile" class="sidebar-link w-full text-left px-3 py-2 rounded-md text-sm font-medium bg-indigo-50 text-indigo-700">
              <span class="flex items-center gap-3">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                </svg>
                Profil
              </span>
            </button>
            <button data-section="account" class="sidebar-link w-full text-left px-3 py-2 rounded-md text-sm font-medium text-gray-600 hover:bg-gray-50">
              <span class="flex items-center gap-3">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                Compte
              </span>
            </button>
            <button data-section="security" class="sidebar-link w-full text-left px-3 py-2 rounded-md text-sm font-medium text-gray-600 hover:bg-gray-50">
              <span class="flex items-center gap-3">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                </svg>
                Sécurité
              </span>
            </button>
          </nav>
          
          <div class="mt-6 pt-6 border-t">
            <button id="logout-sidebar" class="w-full text-left px-3 py-2 rounded-md text-sm font-medium text-red-600 hover:bg-red-50">
              <span class="flex items-center gap-3">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
                </svg>
                Déconnexion
              </span>
            </button>
          </div>
        </div>
      </aside>

      <!-- Content Area -->
      <main class="flex-1 min-w-0">
        
        <!-- Profile Section -->
        <section id="section-profile" class="settings-section bg-white rounded-lg shadow p-6">
          <h2 class="text-xl font-semibold text-gray-900 mb-6">Informations personnelles</h2>
          <form id="profile-form" class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Prénom</label>
                <input type="text" id="first-name" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Nom</label>
                <input type="text" id="last-name" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500" />
              </div>
            </div>
            
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Nom d'utilisateur</label>
              <div class="relative">
                <span class="absolute left-3 top-2 text-gray-500">@</span>
                <input type="text" id="username" class="w-full pl-8 pr-3 py-2 border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500" />
              </div>
            </div>
            
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Bio</label>
              <textarea id="bio" rows="3" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-indigo-500 focus:border-indigo-500"></textarea>
            </div>
            
            <div class="flex items-center justify-between pt-4 border-t">
              <p id="success-message" class="hidden text-green-600 text-sm"></p>
              <p id="error-message" class="hidden text-red-600 text-sm"></p>
              <button type="submit" id="save-profile" class="px-6 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 font-medium ml-auto">
                Enregistrer
              </button>
            </div>
          </form>
        </section>

        <!-- Account Section -->
        <section id="section-account" class="settings-section hidden bg-white rounded-lg shadow p-6">
          <h2 class="text-xl font-semibold text-gray-900 mb-6">Compte</h2>
          <div class="space-y-6">
            <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg">
              <div>
                <p class="font-medium text-gray-900">Email</p>
                <p id="email-display" class="text-sm text-gray-500">-</p>
              </div>
            </div>
            <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg">
              <div>
                <p class="font-medium text-gray-900">Membre depuis</p>
                <p id="member-since" class="text-sm text-gray-500">-</p>
              </div>
            </div>
          </div>
        </section>

        <!-- Security Section -->
        <section id="section-security" class="settings-section hidden bg-white rounded-lg shadow p-6">
          <h2 class="text-xl font-semibold text-gray-900 mb-6">Sécurité</h2>
          <div class="p-4 border border-gray-200 rounded-lg">
            <div class="flex items-center justify-between mb-2">
              <h3 class="font-medium text-gray-900">Mot de passe</h3>
              <button id="change-password" class="px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 text-sm">
                Changer
              </button>
            </div>
            <p class="text-sm text-gray-500">Cliquez pour recevoir un email de réinitialisation</p>
          </div>
        </section>

      </main>
    </div>
  </div>

  <!-- Avatar Modal -->
  <div id="avatar-modal" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden items-center justify-center p-4">
    <div class="bg-white rounded-xl shadow-2xl w-full max-w-4xl max-h-[90vh] overflow-hidden flex flex-col">
      <div class="flex items-center justify-between p-6 border-b">
        <h3 class="text-xl font-semibold text-gray-900">Choisir un avatar</h3>
        <button id="close-avatar-modal" class="text-gray-400 hover:text-gray-600">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
      <div class="flex-1 overflow-y-auto p-6">
        <div id="category-filters" class="flex flex-wrap gap-2 justify-center mb-6"></div>
        <div id="avatar-loading" class="text-center py-8">
          <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-indigo-600"></div>
          <p class="mt-2 text-gray-600">Chargement...</p>
        </div>
        <div id="avatar-grid" class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 gap-4 hidden"></div>
        <div id="no-results" class="hidden text-center py-8 text-gray-500">Aucun avatar trouvé</div>
      </div>
      <div class="border-t p-4 flex justify-end">
        <button id="cancel-avatar" class="px-4 py-2 text-gray-700 hover:bg-gray-100 rounded-lg">Annuler</button>
      </div>
    </div>
  </div>

  <!-- Toast -->
  <div id="toast" class="fixed bottom-4 right-4 transform translate-y-20 opacity-0 transition-all duration-300 z-50">
    <div class="bg-green-600 text-white px-6 py-3 rounded-lg shadow-lg flex items-center gap-2">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
      </svg>
      <span id="toast-message"></span>
    </div>
  </div>
</Layout>

<script>
  import { supabase } from '../lib/supabase';
  import { loadLottieScript, createLottie } from '../utils/lottie';
  
  let currentUserId: string | null = window.__USER_ID__ || null;
  let allAvatars: any[] = [];
  let lottieAnimations: any[] = [];

  async function ensureLottie() {
    await loadLottieScript();
  }

  async function loadProfile() {
    if (!currentUserId) { window.location.href = '/auth/login'; return; }
    
    const { data: profile } = await supabase.from('profiles').select('*').eq('id', currentUserId).single();
    
    if (profile) {
      const fullName = profile.full_name || profile.email?.split('@')[0] || 'Utilisateur';
      document.getElementById('user-name').textContent = fullName;
      document.getElementById('user-username').textContent = '@' + (profile.username || profile.email?.split('@')[0] || 'user');
      document.getElementById('email-display').textContent = profile.email || '';
      document.getElementById('member-since').textContent = new Date(profile.created_at).toLocaleDateString('fr-FR');
      
      const names = (profile.full_name || '').split(' ');
      document.getElementById('first-name').value = names[0] || '';
      document.getElementById('last-name').value = names.slice(1).join(' ') || '';
      document.getElementById('username').value = profile.username || '';
      document.getElementById('bio').value = profile.bio || '';
      
      const initials = fullName.split(' ').map(n => n[0]).join('').slice(0, 2).toUpperCase();
      document.getElementById('avatar-initials-large').textContent = initials;
      
      // Load cover photo
      const coverImg = document.getElementById('cover-img');
      const coverGradient = document.getElementById('cover-gradient');
      if (profile.cover_url) {
        coverImg.src = profile.cover_url;
        coverImg.classList.remove('hidden');
        coverGradient.classList.remove('from-indigo-600', 'to-purple-700');
      }
      
      // Load and display avatar Lottie animation
      if (profile.avatar_lottie_url) {
        await ensureLottie();
        const largeAvatar = document.getElementById('large-avatar');
        largeAvatar.innerHTML = '<div id="header-lottie" class="w-full h-full"></div>';
        window.lottie.loadAnimation({
          container: document.getElementById('header-lottie'),
          renderer: 'svg', loop: true, autoplay: true, path: profile.avatar_lottie_url
        });
      } else if (profile.avatar_url) {
        // Static avatar image
        const largeAvatar = document.getElementById('large-avatar');
        largeAvatar.innerHTML = `<img src="${profile.avatar_url}" alt="Avatar" class="w-full h-full object-cover rounded-2xl" />`;
      }
    }
  }

  // Sidebar navigation
  document.querySelectorAll('.sidebar-link').forEach(link => {
    link.addEventListener('click', () => {
      const section = link.dataset.section;
      document.querySelectorAll('.sidebar-link').forEach(l => {
        l.classList.remove('bg-indigo-50', 'text-indigo-700');
        l.classList.add('text-gray-600', 'hover:bg-gray-50');
      });
      link.classList.remove('text-gray-600', 'hover:bg-gray-50');
      link.classList.add('bg-indigo-50', 'text-indigo-700');
      
      document.querySelectorAll('.settings-section').forEach(s => s.classList.add('hidden'));
      document.getElementById('section-' + section).classList.remove('hidden');
    });
  });

  // Profile form
  document.getElementById('profile-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!currentUserId) return;

    const firstName = document.getElementById('first-name').value;
    const lastName = document.getElementById('last-name').value;
    const fullName = (firstName + ' ' + lastName).trim();
    
    try {
      const { error } = await supabase.from('profiles').upsert({
        id: currentUserId,
        full_name: fullName,
        username: document.getElementById('username').value,
        bio: document.getElementById('bio').value
      }, { onConflict: 'id' });

      if (error) throw error;
      showToast('Profil mis à jour !');
      document.getElementById('user-name').textContent = fullName;
    } catch (err) {
      showToast(err.message || 'Erreur', 'error');
    }
  });

  document.getElementById('change-password')?.addEventListener('click', () => {
    window.location.href = '/auth/forgot-password';
  });

  document.getElementById('logout-sidebar')?.addEventListener('click', async () => {
    try {
      await fetch('/api/auth/logout', { method: 'POST' });
    } catch {}
    localStorage.removeItem('auth_user');
    window.location.href = '/';
  });

  // Cover Photo Upload
  document.getElementById('change-cover-btn')?.addEventListener('click', () => {
    document.getElementById('cover-file-input').click();
  });

  document.getElementById('cover-file-input')?.addEventListener('change', async (e) => {
    const file = e.target.files[0];
    if (!file || !currentUserId) return;

    try {
      showToast('Upload de la cover...');
      
      // Upload to Supabase Storage
      const fileExt = file.name.split('.').pop();
      const fileName = `${currentUserId}-${Date.now()}.${fileExt}`;
      const filePath = `covers/${fileName}`;

      const { error: uploadError } = await supabase.storage
        .from('avatars')
        .upload(filePath, file);

      if (uploadError) throw uploadError;

      // Get public URL
      const { data } = supabase.storage.from('avatars').getPublicUrl(filePath);
      const coverUrl = data.publicUrl;

      // Update profile with new cover URL
      const { error: updateError } = await supabase.from('profiles').upsert({
        id: currentUserId,
        cover_url: coverUrl
      }, { onConflict: 'id' });

      if (updateError) throw updateError;

      // Update UI
      const coverImg = document.getElementById('cover-img');
      const coverGradient = document.getElementById('cover-gradient');
      coverImg.src = coverUrl;
      coverImg.classList.remove('hidden');
      coverGradient.classList.remove('from-indigo-600', 'to-purple-700');

      showToast('Cover photo mise à jour !');
    } catch (err) {
      showToast(err.message || 'Erreur lors du upload', 'error');
    }

    // Reset file input
    e.target.value = '';
  });

  // Avatar Modal
  const avatarModal = document.getElementById('avatar-modal');
  function openModal() { avatarModal.classList.remove('hidden'); avatarModal.classList.add('flex'); loadAvatars(); }
  function closeModal() { avatarModal.classList.add('hidden'); avatarModal.classList.remove('flex'); lottieAnimations.forEach(a => a.destroy && a.destroy()); lottieAnimations = []; }

  document.getElementById('change-avatar-btn')?.addEventListener('click', openModal);
  document.getElementById('close-avatar-modal')?.addEventListener('click', closeModal);
  document.getElementById('cancel-avatar')?.addEventListener('click', closeModal);
  avatarModal?.addEventListener('click', (e) => { if (e.target === avatarModal) closeModal(); });

  async function loadAvatars() {
    document.getElementById('avatar-loading').classList.remove('hidden');
    document.getElementById('avatar-grid').classList.add('hidden');

    try {
      const { data } = await supabase.from('avatars').select('*').eq('is_free', true).order('category');
      allAvatars = data || [];
      
      const categories = [...new Set(allAvatars.map(a => a.category))];
      const filters = document.getElementById('category-filters');
      filters.innerHTML = '<button class="cat-btn px-3 py-1 rounded-full text-sm bg-indigo-600 text-white" data-cat="all">Tous</button>' +
        categories.map(c => '<button class="cat-btn px-3 py-1 rounded-full text-sm bg-gray-200 text-gray-700 hover:bg-gray-300" data-cat="' + c + '">' + c + '</button>').join('');
      
      filters.querySelectorAll('.cat-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          filters.querySelectorAll('.cat-btn').forEach(b => { b.classList.remove('bg-indigo-600', 'text-white'); b.classList.add('bg-gray-200', 'text-gray-700'); });
          btn.classList.remove('bg-gray-200', 'text-gray-700'); btn.classList.add('bg-indigo-600', 'text-white');
          const cat = btn.dataset.cat;
          renderAvatars(cat === 'all' ? allAvatars : allAvatars.filter(a => a.category === cat));
        });
      });

      if (!window.lottie) await ensureLottie();
      renderAvatars(allAvatars);
    } catch (err) { console.error(err); }
    finally { document.getElementById('avatar-loading').classList.add('hidden'); }
  }

  function renderAvatars(avatars) {
    const grid = document.getElementById('avatar-grid');
    const noResults = document.getElementById('no-results');
    if (avatars.length === 0) { grid.classList.add('hidden'); noResults.classList.remove('hidden'); return; }
    
    grid.classList.remove('hidden'); noResults.classList.add('hidden');
    grid.innerHTML = avatars.map(a => '<div class="avatar-card cursor-pointer rounded-lg border-2 border-gray-200 p-3 hover:border-gray-300 transition-all" data-id="' + a.id + '" data-lottie="' + a.lottie_url + '"><div class="aspect-square rounded-lg bg-gray-100 mb-2 flex items-center justify-center overflow-hidden lottie-container"></div><p class="text-xs text-center text-gray-700 truncate">' + a.name + '</p></div>').join('');

    grid.querySelectorAll('.avatar-card').forEach(card => {
      card.addEventListener('click', () => selectAvatar(card.dataset.id));
      const container = card.querySelector('.lottie-container');
      try {
        const anim = window.lottie.loadAnimation({ container, renderer: 'svg', loop: true, autoplay: true, path: card.dataset.lottie });
        anim.setSpeed(0.5); lottieAnimations.push(anim);
      } catch (e) { container.innerHTML = '👤'; }
    });
  }

  async function selectAvatar(avatarId) {
    if (!currentUserId) return;
    
    const avatar = allAvatars.find(a => a.id === avatarId);
    document.querySelectorAll('.avatar-card').forEach(c => { c.classList.toggle('border-indigo-600', c.dataset.id === avatarId); c.classList.toggle('bg-indigo-50', c.dataset.id === avatarId); c.classList.toggle('border-gray-200', c.dataset.id !== avatarId); });

    try {
      const { error } = await supabase.from('profiles').upsert({
        id: currentUserId, avatar_id: avatar.id, avatar_lottie_url: avatar.lottie_url, avatar_url: avatar.preview_url
      }, { onConflict: 'id' });
      if (error) throw error;

      // Update localStorage for immediate header update
      try {
        const raw = localStorage.getItem('auth_user');
        if (raw) {
          const user = JSON.parse(raw);
          user.avatar_url = avatar.preview_url;
          user.avatar_lottie_url = avatar.lottie_url;
          localStorage.setItem('auth_user', JSON.stringify(user));
        }
      } catch {}

      const largeAvatar = document.getElementById('large-avatar');
      largeAvatar.innerHTML = '<div id="header-lottie-new" class="w-full h-full"></div>';
      window.lottie.loadAnimation({ container: document.getElementById('header-lottie-new'), renderer: 'svg', loop: true, autoplay: true, path: avatar.lottie_url });
      showToast('Avatar mis à jour !'); closeModal();
    } catch (err) { 
      showToast(err.message || 'Erreur', 'error');
    }
  }

  function showToast(message, type) {
    const toast = document.getElementById('toast');
    const msg = document.getElementById('toast-message');
    msg.textContent = message;
    toast.querySelector('div').className = type === 'error' ? 'bg-red-600 text-white px-6 py-3 rounded-lg shadow-lg flex items-center gap-2' : 'bg-green-600 text-white px-6 py-3 rounded-lg shadow-lg flex items-center gap-2';
    toast.classList.remove('translate-y-20', 'opacity-0');
    setTimeout(() => toast.classList.add('translate-y-20', 'opacity-0'), 3000);
  }

  loadProfile();
  supabase.auth.onAuthStateChange((e) => { if (e === 'SIGNED_OUT') window.location.href = '/auth/login'; });
</script>
