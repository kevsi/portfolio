---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";

const userId = Astro.locals.session?.user?.id ?? null;
---

<Layout title="Choisir un avatar">
  <!-- Pass server data to client script -->
  {userId && <script is:inline define:vars={{ userId }}>window.__USER_ID__ = userId;</script>}
  <Container>
    <Sectionhead>
      <Fragment slot="title">Choisir un avatar</Fragment>
      <Fragment slot="desc">Sélectionnez un avatar animé pour personnaliser votre profil</Fragment>
    </Sectionhead>

    <!-- Loading state -->
    <div id="loading" class="text-center py-12">
      <div class="inline-block animate-spin rounded-full h-8 w-8 border-b-2 border-indigo-600"></div>
      <p class="mt-2 text-gray-600">Chargement des avatars...</p>
    </div>

    <!-- Auth required -->
    <div id="auth-required" class="hidden text-center py-12">
      <p class="text-gray-600 mb-4">Vous devez être connecté pour accéder à cette page.</p>
      <a href="/auth/login" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700">
        Se connecter
      </a>
      <a href="/settings" class="text-indigo-600 hover:text-indigo-700 font-medium">← Retour aux paramètres</a>
    </div>

    <!-- Main content -->
    <div id="avatar-content" class="hidden py-12">

      <!-- Category Filter -->
      <div id="category-filters" class="flex flex-wrap gap-2 justify-center mb-8"></div>

      <!-- Avatar Grid -->
      <div id="avatar-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4 max-w-6xl mx-auto"></div>

      <!-- Empty State -->
      <div id="no-results" class="hidden text-center py-12">
        <p class="text-gray-500">Aucun avatar trouvé dans cette catégorie</p>
      </div>
    </div>

    <!-- Toast Notification -->
    <div id="toast" class="fixed bottom-4 right-4 transform translate-y-20 opacity-0 transition-all duration-300 z-50">
      <div id="toast-inner" class="bg-green-600 text-white px-6 py-3 rounded-lg shadow-lg flex items-center gap-2">
        <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
        </svg>
        <span id="toast-message">Avatar mis à jour avec succès !</span>
      </div>
    </div>

  </Container>
</Layout>

<script>
  import { supabase } from '../../lib/supabase';
  import { loadLottieScript, createLottie, isLottieLoaded } from '../../utils/lottie';

  interface Avatar {
    id: string;
    name: string;
    category: string;
    lottie_url: string;
    preview_url: string | null;
    is_free: boolean;
  }

  let allAvatars: Avatar[] = [];
  let currentUserId: string | null = (window as any).__USER_ID__ || null;
  let selectedAvatarId: string | null = null;

  // ── Profile ───────────────────────────────────────────────────────────────
  async function fetchCurrentAvatar(userId: string): Promise<string | null> {
    const { data } = await supabase
      .from('profiles')
      .select('avatar_id')
      .eq('id', userId)
      .single();
    return data?.avatar_id ?? null;
  }

  async function selectAvatar(avatar: Avatar) {
    if (!currentUserId) return;

    // Optimistic UI — mark card immediately
    markSelected(avatar.id);

    try {
      const { error } = await supabase
        .from('profiles')
        .update({
          avatar_id: avatar.id,
          avatar_lottie_url: avatar.lottie_url,
          avatar_url: avatar.preview_url ?? null,
        })
        .eq('id', currentUserId);

      if (error) throw error;

      // Sync localStorage so the header updates on next paint
      syncLocalStorage(avatar);

      showToast('Avatar mis à jour avec succès !');
      setTimeout(() => { window.location.href = '/profile'; }, 1500);
    } catch (err) {
      console.error('selectAvatar error:', err);
      showToast('Erreur lors de la mise à jour', true);
      markSelected(selectedAvatarId); // revert optimistic
    }
  }

  function syncLocalStorage(avatar: Avatar) {
    try {
      const raw = localStorage.getItem('auth_user');
      if (raw) {
        const user = JSON.parse(raw);
        user.avatar_url = avatar.preview_url ?? null;
        user.avatar_lottie_url = avatar.lottie_url;
        localStorage.setItem('auth_user', JSON.stringify(user));
      }
    } catch { /* noop */ }
  }

  // ── Render ────────────────────────────────────────────────────────────────
  function renderCategories() {
    const categories = ['all', ...new Set(allAvatars.map(a => a.category))];
    const container = document.getElementById('category-filters')!;

    container.innerHTML = categories.map((cat, i) => `
      <button
        class="category-btn px-4 py-2 rounded-full text-sm font-medium transition-all
               ${i === 0 ? 'bg-indigo-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}"
        data-category="${cat}">
        ${cat === 'all' ? 'Tous' : cat.charAt(0).toUpperCase() + cat.slice(1)}
      </button>
    `).join('');

    container.querySelectorAll<HTMLButtonElement>('.category-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        container.querySelectorAll('.category-btn').forEach(b => {
          b.classList.remove('bg-indigo-600', 'text-white');
          b.classList.add('bg-gray-100', 'text-gray-700');
        });
        btn.classList.add('bg-indigo-600', 'text-white');
        btn.classList.remove('bg-gray-100', 'text-gray-700');

        const cat = btn.dataset.category;
        renderAvatars(cat === 'all' ? allAvatars : allAvatars.filter(a => a.category === cat));
      });
    });
  }

  function renderAvatars(avatars: Avatar[]) {
    const grid = document.getElementById('avatar-grid')!;
    const noResults = document.getElementById('no-results')!;

    if (avatars.length === 0) {
      grid.innerHTML = '';
      noResults.classList.remove('hidden');
      return;
    }
    noResults.classList.add('hidden');

    grid.innerHTML = avatars.map(avatar => {
      const hasPreview = !!avatar.preview_url?.trim();
      const isSelected = avatar.id === selectedAvatarId;

      return `
      <div class="avatar-card group relative bg-white rounded-2xl border-2 transition-all duration-300 cursor-pointer overflow-hidden
                  ${isSelected ? 'border-indigo-500 shadow-lg shadow-indigo-100/50' : 'border-gray-100 hover:border-indigo-300 hover:shadow-xl hover:-translate-y-1'}"
           data-id="${avatar.id}"
           data-lottie-url="${avatar.lottie_url}"
           data-has-preview="${hasPreview}">

        <!-- Selected checkmark -->
        <div class="selected-badge absolute top-2 left-2 z-20 hidden">
          <div class="bg-indigo-600 rounded-full w-6 h-6 flex items-center justify-center shadow-md">
            <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
            </svg>
          </div>
        </div>

        <!-- Thumbnail -->
        <div class="aspect-square bg-gradient-to-br from-gray-50 to-gray-100 relative overflow-hidden">
          ${hasPreview ? `
            <img src="${avatar.preview_url}" alt="${avatar.name}"
                 class="avatar-static absolute inset-0 w-full h-full object-cover transition-all duration-300 group-hover:scale-105" />
            <div class="avatar-lottie absolute inset-0 opacity-0 transition-opacity duration-300 pointer-events-none"></div>
          ` : `
            <div class="avatar-lottie-direct absolute inset-0 pointer-events-none"></div>
          `}

          <!-- Badge -->
          <div class="absolute top-3 right-3 z-10 flex items-center gap-1 text-xs font-bold px-2.5 py-1 rounded-full border backdrop-blur-sm
                      ${avatar.is_free ? 'bg-emerald-100/90 text-emerald-700 border-emerald-200' : 'bg-amber-100/90 text-amber-700 border-amber-200'}">
            <span class="w-1.5 h-1.5 rounded-full ${avatar.is_free ? 'bg-emerald-500' : 'bg-amber-500'}"></span>
            ${avatar.is_free ? 'Gratuit' : 'Pro'}
          </div>
        </div>

        <!-- Info -->
        <div class="p-4 pb-2">
          <p class="font-bold text-gray-900 text-sm truncate">${avatar.name}</p>
          <p class="text-xs text-gray-400 capitalize mt-0.5">${avatar.category}</p>
        </div>

        <!-- Button -->
        <div class="px-4 pb-4">
          <button class="select-btn w-full py-2.5 text-sm font-semibold rounded-xl transition-all duration-200
                         ${isSelected
                           ? 'bg-indigo-100 text-indigo-700 cursor-default'
                           : 'bg-indigo-600 text-white hover:bg-indigo-700 hover:shadow-md'}">
            ${isSelected ? '✓ Sélectionné' : 'Sélectionner'}
          </button>
        </div>
      </div>`;
    }).join('');

    // Mark selected
    if (selectedAvatarId) {
      const sel = grid.querySelector(`[data-id="${selectedAvatarId}"]`);
      sel?.querySelector('.selected-badge')?.classList.remove('hidden');
    }

    // Attach events
    grid.querySelectorAll<HTMLElement>('.avatar-card').forEach(card => {
      const hasPreview = card.dataset.hasPreview === 'true';
      const lottieUrl = card.dataset.lottieUrl!;
      let anim: any = null;

      if (hasPreview) {
        const staticImg = card.querySelector<HTMLElement>('.avatar-static')!;
        const lottieDiv = card.querySelector<HTMLElement>('.avatar-lottie')!;

        card.addEventListener('mouseenter', () => {
          if (!isLottieLoaded()) return;
          staticImg.style.opacity = '0';
          lottieDiv.style.opacity = '1';
          if (!anim) anim = createLottie(lottieDiv, lottieUrl);
          else anim.play();
        });

        card.addEventListener('mouseleave', () => {
          staticImg.style.opacity = '1';
          lottieDiv.style.opacity = '0';
          anim?.pause();
        });
      }

      card.querySelector('.select-btn')?.addEventListener('click', (e) => {
        e.stopPropagation();
        const avatar = allAvatars.find(a => a.id === card.dataset.id);
        if (avatar && avatar.id !== selectedAvatarId) selectAvatar(avatar);
      });
    });

    // Init direct Lottie (no preview) — only if lottie already loaded
    if (isLottieLoaded()) initDirectCards();
  }

  function initDirectCards() {
    document.querySelectorAll<HTMLElement>('.avatar-lottie-direct').forEach(div => {
      const url = div.closest<HTMLElement>('.avatar-card')?.dataset.lottieUrl;
      if (url && !div.dataset.inited) {
        div.dataset.inited = 'true';
        createLottie(div, url, 0.6);
      }
    });
  }

  function markSelected(id: string | null) {
    selectedAvatarId = id;
    document.querySelectorAll<HTMLElement>('.avatar-card').forEach(card => {
      const isSel = card.dataset.id === id;
      card.classList.toggle('border-indigo-500', isSel);
      card.classList.toggle('shadow-indigo-100', isSel);
      card.classList.toggle('border-gray-200', !isSel);
      card.querySelector('.selected-badge')?.classList.toggle('hidden', !isSel);
      const btn = card.querySelector<HTMLElement>('.select-btn');
      if (btn) {
        btn.textContent = isSel ? '✓ Sélectionné' : 'Sélectionner';
        btn.className = `select-btn w-full py-2 text-sm font-medium rounded-lg transition-colors
          ${isSel ? 'bg-indigo-100 text-indigo-700 cursor-default' : 'bg-indigo-600 text-white hover:bg-indigo-700'}`;
      }
    });
  }

  // ── Toast ─────────────────────────────────────────────────────────────────
  function showToast(message: string, isError = false) {
    const toast = document.getElementById('toast')!;
    const inner = document.getElementById('toast-inner')!;
    const msg = document.getElementById('toast-message')!;

    msg.textContent = message;
    inner.className = `${isError ? 'bg-red-600' : 'bg-green-600'} text-white px-6 py-3 rounded-lg shadow-lg flex items-center gap-2`;
    toast.classList.remove('translate-y-20', 'opacity-0');
    setTimeout(() => toast.classList.add('translate-y-20', 'opacity-0'), 3000);
  }

  // ── Init ──────────────────────────────────────────────────────────────────
  async function init() {
    if (!currentUserId) {
      document.getElementById('loading')?.classList.add('hidden');
      document.getElementById('auth-required')?.classList.remove('hidden');
      return;
    }

    // Fetch avatars + current selection in parallel
    const [{ data: avatars, error }, currentAvatarId] = await Promise.all([
      supabase.from('avatars').select('*').order('category').order('name'),
      fetchCurrentAvatar(currentUserId),
    ]);

    if (error || !avatars) {
      console.error('Erreur chargement avatars:', error);
      document.getElementById('loading')?.classList.add('hidden');
      return;
    }

    allAvatars = avatars;
    selectedAvatarId = currentAvatarId;

    renderCategories();
    renderAvatars(allAvatars);

    document.getElementById('loading')?.classList.add('hidden');
    document.getElementById('avatar-content')?.classList.remove('hidden');

    // Load Lottie after UI is visible
    await loadLottieScript();
    initDirectCards();
  }

  init();
</script>

<style>
  .avatar-card:hover .avatar-static { opacity: 0; }
  .avatar-card:hover .avatar-lottie  { opacity: 1; }
</style>