---
// @ts-ignore
import { Icon } from "astro-icon/components";
---

<div class="mt-24">
  <h2 class="text-center text-slate-500">Mes Technologies Favorites</h2>
  <div class="flex gap-8 md:gap-20 items-center justify-center mt-10 flex-wrap">

    <Icon class="size-8 md:size-12" name="simple-icons:docker" />
    <Icon class="size-8 md:size-12" name="simple-icons:react" />
    <Icon class="size-8 md:size-12" name="simple-icons:symfony" />
    <Icon class="size-8 md:size-16" name="simple-icons:tailwindcss" />
    <Icon class="size-8 md:size-16" name="simple-icons:figma" />
    <Icon class="size-8 md:size-12" name="simple-icons:php" />
    <Icon class="size-8 md:size-12" name="simple-icons:nextdotjs" />
    <Icon class="size-8 md:size-12" name="simple-icons:typescript" />
    <Icon class="size-8 md:size-12" name="simple-icons:postman" />

  </div>
</div>
